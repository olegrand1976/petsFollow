# petsFollow — environnement local
PETSFOLLOW_DB_PORT=5437
PETSFOLLOW_REDIS_PORT=6382
PETSFOLLOW_API_PORT=8291
PETSFOLLOW_NUXTJS_PORT=3002
PETSFOLLOW_MAILHOG_SMTP_PORT=1027
PETSFOLLOW_MAILHOG_UI_PORT=8027

DATABASE_URL=postgres://petsfollow:petsfollow@localhost:5437/petsfollow?sslmode=disable
REDIS_ADDR=localhost:6382
REDIS_KEY_PREFIX=petsfollow:
HTTP_ADDR=:8291
JWT_SIGNING_KEY=dev-change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
MIGRATE_ON_BOOT=true
DEV_SEED_ENABLED=true
SMTP_HOST=localhost
SMTP_PORT=1027
SMTP_FROM="petsFollow <noreply@petsfollow.test>"
HEARTRATE_MIN_BPM=60
HEARTRATE_MAX_BPM=140
HEARTRATE_DURATION_SEC=60

NUXT_PUBLIC_API_BASE=http://localhost:8291
NUXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_ID=
PETSFOLLOW_PUBLIC_SITE_URL=http://localhost:3002
PETSFOLLOW_API_PUBLIC_URL=http://localhost:8291

# Stripe billing (mock auto si STRIPE_SECRET_KEY vide)
BILLING_MOCK_ENABLED=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=whsec_test
STRIPE_PRICE_ANNUAL_ONETIME=
STRIPE_PRICE_TRIENNIAL_ONETIME=
STRIPE_PRICE_QUINQUENNIAL_ONETIME=
STRIPE_PRICE_ANNUAL_SUB=
STRIPE_PRICE_TRIENNIAL_SUB=
STRIPE_PRICE_QUINQUENNIAL_SUB=
STRIPE_SUCCESS_URL=petsfollow://payment/success
STRIPE_CANCEL_URL=petsfollow://payment/cancel

GCP_PROJECT_ID=premedica-prod-2025
GCP_RUN_REGION=europe-west9
CUSTOM_DOMAIN=petsfollow.ll-it-sc.be
API_CUSTOM_DOMAIN=api.petsfollow.ll-it-sc.be

# Médias (avatars / photos animaux) — vide en local = disk ./data/uploads
GCS_MEDIA_BUCKET=
# MEDIA_LOCAL_DIR=./data/uploads
